{
  "name": "lumpo",
  "version": "1.0.0",
  "description": "Self-hosted feature-hub REST API: AI tools, media downloaders, scrapers, canvas makers, and mini-games",
  "license": "MIT",
  "main": "server.js",
  "scripts": {
    "postinstall": "python3 -m pip install -U yt-dlp --break-system-packages -q 2>/dev/null || true",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node build.js",
    "test": "jest"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "libphonenumber-js": "^1.10.0",
    "libphonenumber-geo-carrier": "^2.0.0",
    "mailchecker": "^6.0.20",
    "fluent-ffmpeg": "^2.1.3",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "@napi-rs/canvas": "^1.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "form-data": "^4.0.6",
    "google-play-scraper": "^10.0.0",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "nodemailer": "^8.0.11",
    "qrcode": "^1.5.4",
    "sengkrep-ryna": "^2.0.4",
    "sharp": "^0.35.1"
  },
  "overrides": {
    "libphonenumber-geo-carrier": {
      "libphonenumber-js": "$libphonenumber-js"
    }
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "jest": "^30.4.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}