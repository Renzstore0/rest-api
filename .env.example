# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
COOKIE_DOMAIN=

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=lumpo

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# CORS (comma-separated origins allowed for non-/api routes)
CORS_ORIGINS=http://localhost:3000

# Developer/seed account (created on first migration)
DEVELOPER_EMAIL=
DEVELOPER_PASSWORD=

# SMTP (for OTP / transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# AI providers
AI_MODEL=
OPENAI_API_KEY=
NVIDIA_API_KEY=

# Cloudflare Turnstile (optional bot protection)
CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=

# Payment gateway (Orderkuota QRIS)
ORDERKUOTA_USERNAME=
ORDERKUOTA_TOKEN=
ORDERKUOTA_QRIS_STRING=

# YouTube downloader (optional cookie string for age/region-restricted videos)
YT_COOKIE_STRING=
